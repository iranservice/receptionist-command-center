# ─────────────────────────────────────────────────────────────
# Aura AI Receptionist — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials.
#
# When both VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are empty,
# the app runs in "demo mode" with mock data — no backend required.
# ─────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
VITE_SUPABASE_URL=

# Supabase anonymous (public) key — NEVER use service_role key here
VITE_SUPABASE_ANON_KEY=
